# This is an example PKGBUILD file. Use this as a start to creating your own,
# and remove these comments. For more information, see 'man PKGBUILD'.
# NOTE: Please fill out the license field for your package! If it is unknown,
# then please put 'unknown'.

# Guidelines specific to Bazaar, Git, Mercurial and Subversion packages.
# Other VCS sources are not natively supported by makepkg yet.

# Maintainer: Your Name <youremail@domain.com>
pkgname=otf-comic-mono-git # '-bzr', '-git', '-hg' or '-svn'
pkgver=f38ee2896ae8727f13d21efb6d09c739e367651b
pkgrel=1
pkgdesc="Comic Code terminal font (OTF)"
arch=('any')
url="https://github.com/secdrill/Fonts"
license=('unknown')
groups=()
depends=()
makedepends=('git') # 'bzr', 'git', 'mercurial' or 'subversion'
provides=("${pkgname}")
conflicts=("${pkgname}")
replaces=()
backup=()
options=()
install=
source=("${pkgname}::git+https://github.com/secdrill/Fonts")
noextract=()
sha256sums=('SKIP')

# Please refer to the 'USING VCS SOURCES' section of the PKGBUILD man page for
# a description of each element in the source array.

package() {
  install -Dm644 "$srcdir/$pkgname/Comic Code Bold Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Bold Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Bold.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Bold.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Demo Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Demo Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Demo Regular.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Demo Regular.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Bold Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Bold Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Bold.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Bold.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Light Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Light.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Light.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Medium Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Medium Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Medium.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Medium.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Regular.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Regular.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Semibold Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Semibold Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Semibold.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Semibold.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Thin Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Thin Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures Thin.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures Thin.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures UltraLight Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures UltraLight Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Ligatures UltraLight.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Ligatures UltraLight.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Light Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Light Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Light.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Light.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Medium Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Medium Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Medium.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Medium.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Regular.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Regular.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Semibold Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Semibold Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Semibold.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Semibold.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Thin Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Thin Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code Thin.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code Thin.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code UltraLight Italic.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code UltraLight Italic.otf"
  install -Dm644 "$srcdir/$pkgname/Comic Code UltraLight.otf" -t "$pkgdir/usr/share/fonts/OTF/Comic Code UltraLight.otf"

}
